        ttk.Button(actions_frame, text="Restore Themes", command=self.restore_themes).grid(row=5, column=1, padx=5, pady=2, sticky="ew")

        # 4. Emulators & Saves
        emu_lbl = ttk.Label(actions_frame, text="Emulator Configurations & Saves:", font=("Helvetica", 10, "bold"))
